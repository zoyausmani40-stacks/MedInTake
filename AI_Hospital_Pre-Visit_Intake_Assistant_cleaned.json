      "parameters": {
        "formTitle": "Hospital Pre-Visit Medical Intake",
        "formDescription": "Please complete this pre-visit intake form so our care team can prepare for your appointment. The information you provide will be reviewed by our clinical staff before your visit. If any details are incomplete or appear contradictory, your submission may be flagged for manual nurse review. This form does not provide medical advice and is not a substitute for professional care. In an emergency, call your local emergency number.",
        "formFields": {
          "values": [
            {
              "fieldLabel": "Full Name",
              "placeholder": "e.g. Jane Doe",
              "requiredField": true
            },
            {
              "fieldLabel": "Date of Birth",
              "fieldType": "date",
              "requiredField": true
            },
            {
              "fieldLabel": "Email Address",
              "fieldType": "email",
              "placeholder": "e.g. jane@example.com",
              "requiredField": true
            },
            {
              "fieldLabel": "Phone Number",
              "placeholder": "e.g. +1 555 123 4567"
            },
            {
              "fieldLabel": "Reason for Visit",
              "placeholder": "e.g. persistent headache",
              "requiredField": true
            },
            {
              "fieldLabel": "Current Symptoms",
              "fieldType": "textarea",
              "placeholder": "Describe what you are experiencing",
              "requiredField": true
            },
            {
              "fieldLabel": "Symptom Duration",
              "placeholder": "e.g. 3 days, 2 weeks",
              "requiredField": true
            },
            {
              "fieldLabel": "Current Medications",
              "fieldType": "textarea",
              "placeholder": "List any medications you take (optional)"
            },
            {
              "fieldLabel": "Known Allergies",
              "fieldType": "textarea",
              "placeholder": "List any known allergies (optional)"
            },
            {
              "fieldLabel": "Relevant Medical History",
              "fieldType": "textarea",
              "placeholder": "Any relevant past conditions or surgeries (optional)"
            }
          ]
        },
        "options": {
          "buttonLabel": "Submit Intake",
          "path": "hospital-intake",
          "respondWithOptions": {
            "values": {
              "formSubmittedText": "Thank you. Your intake form has been received. Our care team will review your information before your appointment."
            }
          }
        }
      },
