    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\"type\":\"object\",\"properties\":{\"chief_complaint\":{\"type\":\"string\",\"description\":\"The single main reason for the visit in clinical shorthand\"},\"symptoms\":{\"type\":\"array\",\"items\":{\"type\":\"string\"},\"description\":\"List of extracted symptoms\"},\"symptom_duration\":{\"type\":\"string\",\"description\":\"Normalized duration; if multiple conflicting durations exist, note the conflict\"},\"urgency\":{\"type\":\"string\",\"enum\":[\"Routine\",\"Same-Day\",\"Urgent\"]},\"department\":{\"type\":\"string\",\"description\":\"Likely department/specialty e.g. General Medicine, Cardiology, Dermatology\"},\"missing_information\":{\"type\":\"array\",\"items\":{\"type\":\"string\"},\"description\":\"Key fields that are missing but clinically expected\"},\"contradictory_information\":{\"type\":\"array\",\"items\":{\"type\":\"string\"},\"description\":\"Any internal contradictions found between fields\"},\"vague_complaint\":{\"type\":\"boolean\",\"description\":\"True if the complaint is too vague/low-signal to triage confidently\"},\"needs_review\":{\"type\":\"boolean\",\"description\":\"True if a human nurse must review before proceeding\"},\"review_reason\":{\"type\":\"string\",\"description\":\"Short explanation of why review is or is not required\"},\"confidence_score\":{\"type\":\"number\",\"description\":\"Confidence 0-1 in this administrative assessment\"},\"doctor_summary\":{\"type\":\"string\",\"description\":\"One-page doctor-facing pre-consultation summary in clinical shorthand\"}},\"required\":[\"chief_complaint\",\"urgency\",\"department\",\"needs_review\",\"review_reason\",\"confidence_score\",\"doctor_summary\"]}"
      },
